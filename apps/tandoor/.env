# =============================================================================
# CRITICAL: SET THESE SECRET VALUES
# =============================================================================

# CRITICAL: Generate a strong password (e.g., using: openssl rand -base64 32)
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD

# CRITICAL: Generate a Django secret key (e.g., using: openssl rand -base64 32)
TANDOOR_SECRET_KEY=REPLACE_ME_WITH_A_SECURE_KEY

# Needed for security
ALLOWED_HOSTS=${TANDOOR_HOSTNAME}

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
POSTGRES_DB=tandoor
POSTGRES_USER=tandoor
DB_ENGINE=django.db.backends.postgresql
POSTGRES_HOST=tandoor_db
POSTGRES_PORT=5432

# =============================================================================
# TANDOOR APPLICATION SETTINGS
# =============================================================================

# Media serving (1 = gunicorn serves media when no nginx container)
GUNICORN_MEDIA=0

# Debug settings (keep as 0 for production)
DEBUG=0
SQL_DEBUG=0

# Default user preferences
FRACTION_PREF_DEFAULT=0
COMMENT_PREF_DEFAULT=1
SHOPPING_MIN_AUTOSYNC_INTERVAL=5